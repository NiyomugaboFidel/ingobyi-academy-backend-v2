# App (development | staging | production | test)
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
ENABLE_SWAGGER=true
RUN_SEED=false

# Database — local PostgreSQL
# Create DB first: createdb ingobyi_db  (or via pgAdmin)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ingobyi_db

# JWT — persistent login until explicit logout (rolling refresh extends session)
JWT_SECRET=your-secret-here-change-in-production
JWT_EXPIRES_IN=365d
REFRESH_SECRET=your-refresh-secret-change-in-production
REFRESH_EXPIRES_IN=3650d

# Cookie
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Email — required for signup OTP verification
# Option A (recommended): Resend — https://resend.com — free tier, fast delivery
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Ingobyi Academy <onboarding@resend.dev>

# Option B: Gmail SMTP (requires Google App Password — NOT your normal password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your@gmail.com

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

THROTTLE_TTL=60
THROTTLE_LIMIT=100
