# App (development | staging | production | test)
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
ENABLE_SWAGGER=true
RUN_SEED=false

# Database
DATABASE_URL=postgresql://ingobyi:ingobyi_pass@localhost:5432/ingobyi_db

# JWT (min 16 chars — generate: openssl rand -hex 32)
JWT_SECRET=your-secret-here-change-in-production
JWT_EXPIRES_IN=1h
REFRESH_SECRET=your-refresh-secret-change-in-production
REFRESH_EXPIRES_IN=180d

# Cookie (leave COOKIE_DOMAIN empty when using IP address)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# SMTP (optional — OTP codes log to console if unset)
# Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ingobyi.com

# Cloudinary (optional — uploads disabled if unset)
# Option A: individual vars
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Option B: single URL (cloudinary://api_key:api_secret@cloud_name)
# CLOUDINARY_URL=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
