# App (development | staging | production | test)
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://ingobyi-academy-frontend-v2.vercel.app
ENABLE_SWAGGER=true
RUN_SEED=false

# Database — Railway internal (use ${{Postgres.DATABASE_URL}} in Railway dashboard)
DATABASE_URL=postgresql://postgres:alnwxuSOHqScMcXjxJswIESZaGzBnvBr@postgres.railway.internal:5432/railway

# JWT (min 16 chars — generate: openssl rand -hex 32)
JWT_SECRET=your-secret-here-change-in-production
JWT_EXPIRES_IN=30d
REFRESH_SECRET=your-refresh-secret-change-in-production
REFRESH_EXPIRES_IN=365d

# Cookie — leave COOKIE_DOMAIN empty for Railway/Vercel cross-origin HTTPS
COOKIE_DOMAIN=
COOKIE_SECURE=true

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://ingobyi-academy-backend-v2-production.up.railway.app/api/auth/google/callback

# Resend — https://resend.com (required for OTP and notifications)
RESEND_API_KEY=
EMAIL_FROM=Ingobyi Academy <onboarding@resend.dev>

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

THROTTLE_TTL=60
THROTTLE_LIMIT=100
