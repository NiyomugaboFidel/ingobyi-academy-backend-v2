# Railway — backend API service variables
# Paste into Railway → backend service → Variables

# Use staging for test deploys (CORS + Swagger). Switch to production when going live.
NODE_ENV=staging

# Set after frontend is deployed (exact URL, https://, no trailing slash)
FRONTEND_URL=https://your-frontend.up.railway.app
# Or: FRONTEND_URL=https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}

# Link to Postgres plugin (required)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Generate: openssl rand -hex 32
JWT_SECRET=
REFRESH_SECRET=
JWT_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=180d

# Railway provides HTTPS — keep COOKIE_DOMAIN empty
COOKIE_SECURE=true
COOKIE_DOMAIN=

# Test/staging: true. Public production: false
ENABLE_SWAGGER=true

# First deploy only: true loads demo users, then set back to false
RUN_SEED=false

THROTTLE_TTL=60
THROTTLE_LIMIT=200

# Optional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ingobyi.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-api.up.railway.app/api/auth/google/callback
